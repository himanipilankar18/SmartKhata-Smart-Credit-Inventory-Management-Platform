generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  OWNER
  MANAGER
  STAFF

  @@map("user_role")
}

enum CustomerStatus {
  ACTIVE
  INACTIVE
  BLOCKED

  @@map("customer_status")
}

enum ProductUnit {
  PIECE
  KILOGRAM
  LITER
  PACK
  BOX
  METER

  @@map("product_unit")
}

enum TransactionType {
  SALE
  PAYMENT
  CREDIT
  EXPENSE

  @@map("transaction_type")
}

enum TransactionStatus {
  DRAFT
  POSTED
  VOIDED

  @@map("transaction_status")
}

enum PaymentMethod {
  CASH
  UPI
  BANK_TRANSFER
  CARD
  CREDIT

  @@map("payment_method")
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  phone        String?  @unique
  passwordHash String   @map("password_hash")
  role         UserRole @default(OWNER)
  isActive     Boolean  @default(true) @map("is_active")
  lastLoginAt  DateTime? @map("last_login_at")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  createdCustomers    Customer[]     @relation("CustomerCreatedBy")
  updatedCustomers    Customer[]     @relation("CustomerUpdatedBy")
  createdCategories   Category[]     @relation("CategoryCreatedBy")
  updatedCategories   Category[]     @relation("CategoryUpdatedBy")
  createdProducts     Product[]      @relation("ProductCreatedBy")
  updatedProducts     Product[]      @relation("ProductUpdatedBy")
  createdTransactions Transaction[]  @relation("TransactionCreatedBy")

  @@index([role])
  @@index([isActive])
  @@map("users")
}

model Customer {
  id                 String         @id @default(cuid())
  name               String
  email              String?        @unique
  phone              String?        @unique
  address            String?
  city               String?
  creditLimit        Decimal        @default(0) @db.Decimal(14, 2) @map("credit_limit")
  outstandingBalance Decimal        @default(0) @db.Decimal(14, 2) @map("outstanding_balance")
  status             CustomerStatus @default(ACTIVE)
  notes              String?
  isActive           Boolean        @default(true) @map("is_active")
  createdById        String?        @map("created_by_id")
  updatedById        String?        @map("updated_by_id")
  createdAt          DateTime       @default(now()) @map("created_at")
  updatedAt          DateTime       @updatedAt @map("updated_at")

  createdBy    User?            @relation("CustomerCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy    User?            @relation("CustomerUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  transactions Transaction[]

  @@index([name])
  @@index([phone])
  @@index([status])
  @@index([isActive, outstandingBalance])
  @@map("customers")
}

model Category {
  id          String    @id @default(cuid())
  name        String
  slug        String    @unique
  description String?
  isActive    Boolean   @default(true) @map("is_active")
  sortOrder   Int       @default(0) @map("sort_order")
  createdById String?   @map("created_by_id")
  updatedById String?   @map("updated_by_id")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  createdBy User?    @relation("CategoryCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy User?    @relation("CategoryUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  products   Product[]

  @@index([name])
  @@index([isActive, sortOrder])
  @@map("categories")
}

model Product {
  id            String      @id @default(cuid())
  sku           String      @unique
  name          String
  description   String?
  categoryId    String      @map("category_id")
  unit          ProductUnit @default(PIECE)
  costPrice     Decimal     @default(0) @db.Decimal(14, 2) @map("cost_price")
  salePrice     Decimal     @default(0) @db.Decimal(14, 2) @map("sale_price")
  stockQuantity Int         @default(0) @map("stock_quantity")
  reorderLevel  Int         @default(0) @map("reorder_level")
  isActive      Boolean     @default(true) @map("is_active")
  createdById   String?     @map("created_by_id")
  updatedById   String?     @map("updated_by_id")
  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime    @updatedAt @map("updated_at")

  category  Category          @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  createdBy User?             @relation("ProductCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy User?             @relation("ProductUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  items     TransactionItem[]

  @@index([categoryId])
  @@index([name])
  @@index([isActive, stockQuantity])
  @@map("products")
}

model Transaction {
  id                String            @id @default(cuid())
  transactionNumber String            @unique @map("transaction_number")
  customerId        String            @map("customer_id")
  createdById       String?           @map("created_by_id")
  type              TransactionType
  status            TransactionStatus @default(POSTED)
  paymentMethod     PaymentMethod?    @map("payment_method")
  subtotal          Decimal           @default(0) @db.Decimal(14, 2)
  discountTotal     Decimal           @default(0) @db.Decimal(14, 2) @map("discount_total")
  taxTotal          Decimal           @default(0) @db.Decimal(14, 2) @map("tax_total")
  grandTotal        Decimal           @default(0) @db.Decimal(14, 2) @map("grand_total")
  note              String?
  transactionAt     DateTime          @default(now()) @map("transaction_at")
  createdAt         DateTime          @default(now()) @map("created_at")
  updatedAt         DateTime          @updatedAt @map("updated_at")

  customer  Customer          @relation(fields: [customerId], references: [id], onDelete: Restrict)
  createdBy User?             @relation("TransactionCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  items     TransactionItem[]

  @@index([customerId])
  @@index([createdById])
  @@index([type, transactionAt])
  @@index([status, transactionAt])
  @@map("transactions")
}

model TransactionItem {
  id             String   @id @default(cuid())
  transactionId  String   @map("transaction_id")
  productId      String   @map("product_id")
  quantity       Decimal  @db.Decimal(14, 3)
  unitPrice      Decimal  @db.Decimal(14, 2) @map("unit_price")
  discountAmount Decimal  @default(0) @db.Decimal(14, 2) @map("discount_amount")
  lineTotal      Decimal  @db.Decimal(14, 2) @map("line_total")
  createdAt      DateTime @default(now()) @map("created_at")

  transaction Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  product     Product     @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@index([transactionId])
  @@index([productId])
  @@index([transactionId, productId])
  @@map("transaction_items")
}

